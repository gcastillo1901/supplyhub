generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//
// ENUMS
//

enum CustomerType {
  cash
  credit
}

enum SaleStatus {
  paid
  pending
}

enum PaymentMethod {
  cash
  transfer
}

enum CashRegisterStatus {
  open
  closed
}

enum MovementType {
  income
  expense
}

enum UserRole {
  admin
  cashier
}

//
// USER MODEL (Para Auditoría)
//

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      UserRole @default(cashier)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdSales      Sale[]         @relation("CreatedSales")
  updatedSales      Sale[]         @relation("UpdatedSales")
  createdProducts   Product[]      @relation("CreatedProducts")
  updatedProducts   Product[]      @relation("UpdatedProducts")
}

//
// CATEGORY
//

model Category {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  products    Product[]
}

//
// PRODUCT
//

model Product {
  id            Int       @id @default(autoincrement())
  code          String    @unique
  name          String
  categoryId    Int
  purchasePrice Decimal   @db.Decimal(12, 2)
  salePrice     Decimal   @db.Decimal(12, 2)
  stock         Int       @default(0)
  minimumStock  Int       @default(0)

  createdById   Int?
  updatedById   Int?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  category      Category  @relation(fields: [categoryId], references: [id])

  purchaseDetails PurchaseDetail[]
  saleDetails     SaleDetail[]

  createdBy     User? @relation("CreatedProducts", fields: [createdById], references: [id])
  updatedBy     User? @relation("UpdatedProducts", fields: [updatedById], references: [id])

  @@index([name])
}

//
// SUPPLIER
//

model Supplier {
  id             Int       @id @default(autoincrement())
  name           String
  identification String    @unique
  phone          String?
  address        String?
  email          String?   @unique

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  purchases      Purchase[]
}

//
// CUSTOMER
//

model Customer {
  id             Int           @id @default(autoincrement())
  name           String
  identification String?       @unique
  phone          String?
  address        String?
  email          String?       @unique

  customerType   CustomerType  @default(cash)
  creditLimit    Decimal       @default(0) @db.Decimal(12, 2)
  currentBalance Decimal       @default(0) @db.Decimal(12, 2)

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  sales          Sale[]

  @@index([name])
}

//
// PURCHASE
//

model Purchase {
  id           Int       @id @default(autoincrement())
  supplierId   Int
  purchaseDate DateTime
  total        Decimal   @db.Decimal(14, 2)

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  supplier     Supplier  @relation(fields: [supplierId], references: [id])
  details      PurchaseDetail[]
}

//
// PURCHASE DETAIL
//

model PurchaseDetail {
  id            Int      @id @default(autoincrement())
  purchaseId    Int
  productId     Int
  quantity      Int
  purchasePrice Decimal  @db.Decimal(12, 2)
  subtotal      Decimal  @db.Decimal(14, 2)

  purchase      Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product       Product  @relation(fields: [productId], references: [id])
}

//
// SALE
//

model Sale {
  id            Int            @id @default(autoincrement())
  customerId    Int?
  saleDate      DateTime
  subtotal      Decimal        @db.Decimal(14, 2)
  tax           Decimal        @default(0) @db.Decimal(14, 2)
  total         Decimal        @db.Decimal(14, 2)
  paymentMethod PaymentMethod
  status        SaleStatus     @default(paid)

  createdById   Int?
  updatedById   Int?

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  customer      Customer?      @relation(fields: [customerId], references: [id])
  details       SaleDetail[]

  createdBy     User? @relation("CreatedSales", fields: [createdById], references: [id])
  updatedBy     User? @relation("UpdatedSales", fields: [updatedById], references: [id])
}

//
// SALE DETAIL
//

model SaleDetail {
  id         Int      @id @default(autoincrement())
  saleId     Int
  productId  Int
  quantity   Int
  salePrice  Decimal  @db.Decimal(12, 2)
  subtotal   Decimal  @db.Decimal(14, 2)

  sale       Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id])
}

//
// CASH REGISTER
//

model CashRegister {
  id            Int                 @id @default(autoincrement())
  openingDate   DateTime
  openingAmount Decimal             @db.Decimal(14, 2)
  closingDate   DateTime?
  closingAmount Decimal?            @db.Decimal(14, 2)
  difference    Decimal?            @db.Decimal(14, 2)
  status        CashRegisterStatus  @default(open)

  movements     CashMovement[]
}

//
// CASH MOVEMENT
//

model CashMovement {
  id             Int         @id @default(autoincrement())
  cashRegisterId Int
  movementType   MovementType
  description    String?
  amount         Decimal     @db.Decimal(14, 2)
  movementDate   DateTime    @default(now())

  cashRegister   CashRegister @relation(fields: [cashRegisterId], references: [id], onDelete: Cascade)
}